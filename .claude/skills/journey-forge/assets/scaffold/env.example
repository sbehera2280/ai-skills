# Copy to .env and adjust. The Playwright config reads these.

# Base URL the suite runs against. Use prod for read-only journeys, or your staging
# URL for fuller coverage (including form submission, see ALLOW_FORM_SUBMIT).
BASE_URL={{BASE_URL}}

# Optional non-production base URL. journey-forge points form-submission flows here.
STAGING_URL=

# Safety gate. Form journeys are ASSERT-ONLY by default (verify render + client-side
# validation, never submit). A real submit is allowed ONLY when this is "1" AND
# BASE_URL equals STAGING_URL. It can never fire against production by accident.
ALLOW_FORM_SUBMIT=0
