{
  "name": "{{PROJECT_NAME}}",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Sitemap-driven, self-verifying Playwright E2E journey tests generated by the journey-forge skill.",
  "scripts": {
    "setup": "npm install && npx playwright install chromium",
    "test": "playwright test",
    "test:headed": "playwright test --headed",
