    "report": "playwright show-report",
    "typecheck": "tsc --noEmit",
    "forge:init": "node .claude/skills/journey-forge/scripts/init.mjs",
    "forge:scaffold": "node .claude/skills/journey-forge/scripts/scaffold.mjs",
    "forge:parse": "node .claude/skills/journey-forge/scripts/parse-sitemap.mjs",
    "forge:status": "node .claude/skills/journey-forge/scripts/forge-status.mjs",
    "forge:confirm": "node .claude/skills/journey-forge/scripts/confirm.mjs",
    "forge:add": "node .claude/skills/journey-forge/scripts/add-journey.mjs",
    "forge:inspect": "node .claude/skills/journey-forge/scripts/inspect-page.mjs"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.0",
    "@playwright/test": "^1.61.0",
    "@types/node": "^22.10.0",
    "axe-core": "^4.12.0",
    "fast-xml-parser": "^4.5.0",
